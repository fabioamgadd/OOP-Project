<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hotel.gui.controllers.GuestDashboardController"
            prefWidth="1100" prefHeight="680">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20">
            <Label text="HOTEL" style="-fx-text-fill:white; -fx-font-size:15px; -fx-font-weight:bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" text="Welcome" styleClass="label" style="-fx-text-fill:#94A3B8; -fx-font-size:12px;"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-secondary"
                    style="-fx-font-size:12px; -fx-padding:5 14 5 14;"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="2">
            <Button fx:id="btnChat" text="💬 Support Chat" onAction="#showChat"
                    styleClass="sidebar-btn sidebar-chat-btn" maxWidth="Infinity"/>
            <Button fx:id="btnRooms"        text="🏨  Browse Rooms"       onAction="#showRooms"        styleClass="sidebar-btn"/>
            <Button fx:id="btnReserve"      text="📅  Make Reservation"   onAction="#showMakeReservation" styleClass="sidebar-btn"/>
            <Button fx:id="btnMyRes"        text="📋  My Reservations"    onAction="#showMyReservations" styleClass="sidebar-btn"/>
            <Button fx:id="btnPay"          text="💳  Pay Invoice"        onAction="#showPayInvoice"   styleClass="sidebar-btn"/>
            <Button fx:id="btnInvoices"     text="🧾  My Invoices"        onAction="#showInvoices"     styleClass="sidebar-btn"/>
            <Button fx:id="btnDeposit"      text="💰  Deposit Balance"    onAction="#showDeposit"      styleClass="sidebar-btn"/>
            <Button fx:id="btnProfile"      text="👤  My Profile"         onAction="#showProfile"      styleClass="sidebar-btn"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <StackPane fx:id="contentArea" style="-fx-padding:24;">
                <!-- Content panes loaded dynamically by controller -->
            </StackPane>
        </ScrollPane>
    </center>

</BorderPane>
