<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="hotel.gui.controllers.ChatController"
      spacing="10" prefWidth="400" prefHeight="500" styleClass="card" style="-fx-padding: 15;">
    
    <Label text="Live Chat" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0F2044;"/>
    
    <TextArea fx:id="chatArea" editable="false" VBox.vgrow="ALWAYS" wrapText="true"
              style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
              
    <HBox spacing="10">
        <TextField fx:id="inputField" HBox.hgrow="ALWAYS" promptText="Type a message..." onAction="#sendMessage"/>
        <Button text="Send" onAction="#sendMessage" styleClass="btn-primary" style="-fx-padding: 6 15 6 15;"/>
    </HBox>
</VBox>
